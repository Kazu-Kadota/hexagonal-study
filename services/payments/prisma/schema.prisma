generator client {
  provider = "prisma-client"
  output   = "../src/generated/payments"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  pending
  created
  cancelled
}

enum Currency {
  brl
  usd
  cad
  eur
}

model Payments {
  id          String   @id @default(uuid())
  idempotency_key String
  orderId  String
  amount      Float
  currency    Currency
  status      Status
  stripePaymentIntentId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([id])
  @@map("payments")
}
